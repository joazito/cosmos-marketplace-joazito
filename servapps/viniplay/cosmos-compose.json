{
    "cosmos-installer": {},
    "minVersion": "0.9.0",
    "name": "viniplay",
    "services": {
        "{ServiceName}": {
            "image": "ardovini/viniplay:latest",
            "container_name": "{ServiceName}",
            "hostname": "{ServiceName}",
            "restart": "unless-stopped",
            "environment": [
                "SESSION_SECRET={Passwords.0}",
                "NODE_ENV=production"
            ],
            "devices": [
                "/dev/dri:/dev/dri"
            ],
            "volumes": [
                {
                    "type": "volume",
                    "source": "{ServiceName}-data",
                    "target": "/data"
                },
                {
                    "type": "volume",
                    "source": "{ServiceName}-dvr",
                    "target": "/dvr"
                }
            ],
            "routes": [
                {
                    "name": "{ServiceName}",
                    "description": "Expose {ServiceName} to the web",
                    "useHost": true,
                    "target": "http://{ServiceName}:8998",
                    "mode": "SERVAPP",
                    "Timeout": 14400000,
                    "ThrottlePerMinute": 12000,
                    "BlockCommonBots": true,
                    "SmartShield": {
                        "Enabled": true
                    }
                }
            ],
            "labels": {
                "cosmos-persistent-env": "SESSION_SECRET",
                "cosmos-force-network-secured": "true",
                "cosmos-auto-update": "true",
                "cosmos-icon": "https://joazito.github.io/cosmos-marketplace-joazito/servapps/viniplay/icon.png",
                "cosmos-stack": "{ServiceName}",
                "cosmos-stack.main": "{ServiceName}"
            }
        }
    },
    "volumes": {
        "{ServiceName}-data": {
            "name": "{ServiceName}-data",
            "driver": "local"
        },
        "{ServiceName}-dvr": {
            "name": "{ServiceName}-dvr",
            "driver": "local"
        }
    }
}
