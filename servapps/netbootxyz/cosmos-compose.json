{
    "cosmos-installer": {},
    "minVersion": "0.9.0",
    "name": "netbootxyz",
    "services": {
        "{ServiceName}": {
            "image": "netbootxyz/netbootxyz:latest",
            "container_name": "{ServiceName}",
            "hostname": "{ServiceName}",
            "restart": "unless-stopped",
            "environment": [
                "TZ=auto",
                "WEB_APP_PORT=3000",
                "NGINX_PORT=80"
            ],
            "volumes": [
                {
                    "type": "volume",
                    "source": "{ServiceName}-config",
                    "target": "/config"
                },
                {
                    "type": "volume",
                    "source": "{ServiceName}-assets",
                    "target": "/assets"
                }
            ],
            "routes": [
                {
                    "name": "{ServiceName}",
                    "description": "Expose {ServiceName} web UI to the web",
                    "useHost": true,
                    "target": "http://{ServiceName}:3000",
                    "mode": "SERVAPP",
                    "Timeout": 14400000,
                    "ThrottlePerMinute": 12000,
                    "BlockCommonBots": true,
                    "SmartShield": {
                        "Enabled": true
                    }
                }
            ],
            "labels": {
                "cosmos-force-network-secured": "true",
                "cosmos-auto-update": "true",
                "cosmos-icon": "https://joazito.github.io/cosmos-marketplace-joazito/servapps/netbootxyz/icon.png",
                "cosmos-stack": "{ServiceName}",
                "cosmos-stack-main": "{ServiceName}"
            }
        }
    },
    "volumes": {
        "{ServiceName}-config": {
            "name": "{ServiceName}-config",
            "driver": "local"
        },
        "{ServiceName}-assets": {
            "name": "{ServiceName}-assets",
            "driver": "local"
        }
    }
}
