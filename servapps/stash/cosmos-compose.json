{
    "cosmos-installer": {},
    "minVersion": "0.9.0",
    "name": "stash",
    "services": {
        "{ServiceName}": {
            "image": "stashapp/stash:latest",
            "container_name": "{ServiceName}",
            "hostname": "{ServiceName}",
            "restart": "unless-stopped",
            "environment": [
                "TZ=auto"
            ],
            "volumes": [
                {
                    "type": "volume",
                    "source": "{ServiceName}-config",
                    "target": "/root/.stash"
                },
                {
                    "type": "volume",
                    "source": "{ServiceName}-data",
                    "target": "/data"
                },
                {
                    "type": "volume",
                    "source": "{ServiceName}-metadata",
                    "target": "/metadata"
                },
                {
                    "type": "volume",
                    "source": "{ServiceName}-cache",
                    "target": "/cache"
                },
                {
                    "type": "volume",
                    "source": "{ServiceName}-generated",
                    "target": "/generated"
                },
                {
                    "type": "bind",
                    "source": "/etc/localtime:ro",
                    "target": "/etc/localtime:ro"
                }
            ],
            "routes": [
                {
                    "name": "{ServiceName}",
                    "description": "Expose {ServiceName} to the web",
                    "useHost": true,
                    "target": "http://{ServiceName}:9999",
                    "mode": "SERVAPP",
                    "Timeout": 14400000,
                    "ThrottlePerMinute": 12000,
                    "BlockCommonBots": true,
                    "SmartShield": {
                        "Enabled": true
                    }
                }
            ],
            "labels": {
                "cosmos-force-network-secured": "true",
                "cosmos-auto-update": "true",
                "cosmos-icon": "https://joazito.github.io/cosmos-marketplace-joazito/servapps/stash/icon.png",
                "cosmos-stack": "{ServiceName}",
                "cosmos-stack-main": "{ServiceName}"
            }
        }
    },
    "volumes": {
        "{ServiceName}-config": {
            "name": "{ServiceName}-config",
            "driver": "local"
        },
        "{ServiceName}-data": {
            "name": "{ServiceName}-data",
            "driver": "local"
        },
        "{ServiceName}-metadata": {
            "name": "{ServiceName}-metadata",
            "driver": "local"
        },
        "{ServiceName}-cache": {
            "name": "{ServiceName}-cache",
            "driver": "local"
        },
        "{ServiceName}-generated": {
            "name": "{ServiceName}-generated",
            "driver": "local"
        }
    }
}
