{
    "cosmos-installer": {},
    "minVersion": "0.9.0",
    "name": "wallos",
    "services": {
        "{ServiceName}": {
            "image": "bellamy/wallos:latest",
            "container_name": "{ServiceName}",
            "hostname": "{ServiceName}",
            "restart": "unless-stopped",
            "environment": [
                "TZ=auto"
            ],
            "volumes": [
                {
                    "type": "volume",
                    "source": "{ServiceName}-db",
                    "target": "/var/www/html/db"
                },
                {
                    "type": "volume",
                    "source": "{ServiceName}-logos",
                    "target": "/var/www/html/images/uploads/logos"
                },
                {
                    "type": "bind",
                    "source": "/etc/localtime:ro",
                    "target": "/etc/localtime:ro"
                }
            ],
            "routes": [
                {
                    "name": "{ServiceName}",
                    "description": "Expose {ServiceName} to the web",
                    "useHost": true,
                    "target": "http://{ServiceName}:80",
                    "mode": "SERVAPP",
                    "Timeout": 14400000,
                    "ThrottlePerMinute": 12000,
                    "BlockCommonBots": true,
                    "SmartShield": {
                        "Enabled": true
                    }
                }
            ],
            "labels": {
                "cosmos-force-network-secured": "true",
                "cosmos-auto-update": "true",
                "cosmos-icon": "https://joazito.github.io/cosmos-marketplace-joazito/servapps/wallos/icon.png",
                "cosmos-stack": "{ServiceName}",
                "cosmos-stack.main": "{ServiceName}"
            }
        }
    },
    "volumes": {
        "{ServiceName}-db": {
            "name": "{ServiceName}-db",
            "driver": "local"
        },
        "{ServiceName}-logos": {
            "name": "{ServiceName}-logos",
            "driver": "local"
        }
    }
}
